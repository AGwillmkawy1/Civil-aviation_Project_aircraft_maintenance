# Environment Variables Configuration
# Copy this to .env and fill in your values

# API Configuration
API_TITLE=Aircraft Predictive Maintenance API
API_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# CORS Configuration (separate multiple origins with comma)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/api.log

# Model Configuration
MODEL_PATH=notebooks/artifacts/best_model.pkl
SCALER_PATH=notebooks/artifacts/scaler.pkl
FEATURE_NAMES_PATH=notebooks/artifacts/feature_names.pkl

# Database (if using persistence)
# DATABASE_URL=postgresql://user:password@localhost/aircraft_db

# Authentication (if implementing API keys)
API_KEY_ENABLED=False
# API_KEY=your-secret-key-here

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_DOCS_URL=http://localhost:8000/docs

# Deployment (use on production server)
# ENVIRONMENT=production
# SSL_ENABLED=True
# SSL_CERT_PATH=/etc/ssl/certs/
